{
  "name": "cokenhe.github.io",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/deploy-site.mjs",
    "build:open-design": "OPEN_DESIGN_BUILD=1 vite build && node scripts/deploy-open-design.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node scripts/check-site.mjs && node --test tests/*.test.mjs",
    "test:e2e": "node scripts/verify-portal.mjs",
    "verify": "npm run build && npm run test",
    "verify:open-design": "npm run build:open-design && npm run test"
  },
  "dependencies": {
    "@vitejs/plugin-react-swc": "4.3.1",
    "framer-motion": "10.16.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "vite": "8.1.3"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
